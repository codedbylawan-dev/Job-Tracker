# Backend environment variables
# JWT_SECRET: Use a strong random string (min 32 chars). Generate one at https://generate-random.org
JWT_SECRET=your_super_secret_key_change_this_in_production_min_32_chars_example_AbCd1234EfGh5678

# PORT: Server port (optional, defaults to 5000)
PORT=5000

# FRONTEND_URL: URL of your deployed frontend (set in Render dashboard, not here!)
# Example: https://your-app.vercel.app
FRONTEND_URL=http://localhost:3000
